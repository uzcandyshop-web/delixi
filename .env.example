# ==== Telegram ====
BOT_TOKEN=123456:AA-your-bot-token-from-BotFather
WEBAPP_URL=https://delixi-api.onrender.com/static/scanner.html

# ==== Security ====
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
QR_SECRET=replace_me_with_64_hex_chars

# ==== Database ====
# Render will inject DATABASE_URL automatically for managed PostgreSQL
DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/delixi

# ==== Admins ====
# Comma-separated Telegram user IDs that get admin role on /start
ADMIN_TG_IDS=123456789,987654321

# ==== App ====
APP_NAME=DELIXI
LOG_LEVEL=INFO
